---
import DocsLayout from '../layouts/DocsLayout.astro';
---

<DocsLayout title="Home">
  <div class="hero">
    <h1>Chassis UI</h1>
    <p class="tagline">
      A framework-agnostic design system bridge. Switch between
      <strong>Material</strong>, <strong>Polaris</strong>, <strong>Carbon</strong>,
      <strong>Apple HIG</strong>, and more by toggling the theme — no code changes required.
    </p>
    <p class="subtitle">
      Try it now — use the theme switcher in the header to see every component transform instantly.
    </p>

    <div class="demo-grid">
      <div class="demo-card">
        <h3>Buttons</h3>
        <div class="demo-row">
          <chassis-button variant="primary">Primary</chassis-button>
          <chassis-button variant="secondary">Secondary</chassis-button>
          <chassis-button variant="link">Link</chassis-button>
        </div>
      </div>

      <div class="demo-card">
        <h3>Input</h3>
        <chassis-input label="Email address" placeholder="you@example.com" type="email"></chassis-input>
      </div>

      <div class="demo-card">
        <h3>Controls</h3>
        <div class="demo-row">
          <chassis-checkbox label="Accept terms"></chassis-checkbox>
          <chassis-switch label="Dark mode"></chassis-switch>
        </div>
      </div>

      <div class="demo-card">
        <h3>Badges</h3>
        <div class="demo-row">
          <chassis-badge variant="default">Default</chassis-badge>
          <chassis-badge variant="success">Success</chassis-badge>
          <chassis-badge variant="warning">Warning</chassis-badge>
          <chassis-badge variant="error">Error</chassis-badge>
          <chassis-badge variant="info">Info</chassis-badge>
        </div>
      </div>
    </div>

    <div class="features">
      <div class="feature">
        <h3>🔌 Framework Agnostic</h3>
        <p>Web Components at the core. First-class React, Astro, and Svelte wrappers.</p>
      </div>
      <div class="feature">
        <h3>🎨 Theme Hot-Swap</h3>
        <p>Switch between design systems in under 100ms via CSS custom properties.</p>
      </div>
      <div class="feature">
        <h3>♿ Accessible</h3>
        <p>WCAG 2.1 AA compliant. ARIA roles, keyboard navigation, focus management.</p>
      </div>
      <div class="feature">
        <h3>🪶 Lightweight</h3>
        <p>~5KB runtime (Lit). Zero framework dependencies. Tree-shakeable exports.</p>
      </div>
    </div>

    <h2 class="section-heading">Supported Design Systems</h2>
    <p class="section-intro">Chassis UI ships with 12 design system themes. Select any theme from the dropdown above to see every component on this site transform instantly.</p>

    <div class="ds-grid">
      <div class="ds-card">
        <span class="ds-swatch" style="background:#6750A4"></span>
        <div class="ds-info">
          <h3>Material Design 3</h3>
          <p>Created by <strong>Google</strong>. The latest evolution of Material Design, powering Android, Google apps, and Flutter. Emphasizes dynamic color, rounded shapes, and expressive motion.</p>
        </div>
      </div>
      <div class="ds-card">
        <span class="ds-swatch" style="background:#0F6CBD"></span>
        <div class="ds-info">
          <h3>Fluent</h3>
          <p>Created by <strong>Microsoft</strong>. The design language behind Windows 11, Microsoft 365, and Teams. Known for subtle depth cues, clean typography, and layered surfaces.</p>
        </div>
      </div>
      <div class="ds-card">
        <span class="ds-swatch" style="background:#007AFF"></span>
        <div class="ds-info">
          <h3>Apple HIG</h3>
          <p>Created by <strong>Apple</strong>. The Human Interface Guidelines define the look and feel of iOS, macOS, and visionOS. Characterized by generous radii, translucency, and precision spacing.</p>
        </div>
      </div>
      <div class="ds-card">
        <span class="ds-swatch" style="background:#0176D3"></span>
        <div class="ds-info">
          <h3>Lightning</h3>
          <p>Created by <strong>Salesforce</strong>. The Lightning Design System powers the world's largest CRM platform. Built for data-dense enterprise applications with bold typography and structured layouts.</p>
        </div>
      </div>
      <div class="ds-card">
        <span class="ds-swatch" style="background:#6200EE"></span>
        <div class="ds-info">
          <h3>Material Design 2</h3>
          <p>Created by <strong>Google</strong>. The predecessor to Material 3, still widely used across millions of Android apps and the web. Defined by elevation shadows, dense purple palette, and contained shapes.</p>
        </div>
      </div>
      <div class="ds-card">
        <span class="ds-swatch" style="background:#0F62FE"></span>
        <div class="ds-info">
          <h3>Carbon</h3>
          <p>Created by <strong>IBM</strong>. Carbon is IBM's open-source design system for products and digital experiences. Recognizable by sharp corners, structured grids, and the IBM Plex typeface.</p>
        </div>
      </div>
      <div class="ds-card">
        <span class="ds-swatch" style="background:#0052CC"></span>
        <div class="ds-info">
          <h3>Atlassian Design System</h3>
          <p>Created by <strong>Atlassian</strong>. Powers Jira, Confluence, Trello, and Bitbucket. Focused on clarity and efficiency for team collaboration tools with compact, information-rich interfaces.</p>
        </div>
      </div>
      <div class="ds-card">
        <span class="ds-swatch" style="background:#0265DC"></span>
        <div class="ds-info">
          <h3>Spectrum</h3>
          <p>Created by <strong>Adobe</strong>. Spectrum is Adobe's design system for creative and enterprise products like Photoshop, Illustrator, and Experience Cloud. Features pill-shaped buttons and precise accessibility.</p>
        </div>
      </div>
      <div class="ds-card">
        <span class="ds-swatch" style="background:#008060"></span>
        <div class="ds-info">
          <h3>Polaris</h3>
          <p>Created by <strong>Shopify</strong>. Polaris powers the Shopify admin and merchant ecosystem. Designed for commerce interfaces with a focus on clarity, efficiency, and merchant empowerment.</p>
        </div>
      </div>
      <div class="ds-card">
        <span class="ds-swatch" style="background:#1F883D"></span>
        <div class="ds-info">
          <h3>Primer</h3>
          <p>Created by <strong>GitHub</strong>. Primer is the design system behind GitHub.com. Built for developer tools with systematic spacing, a green-accented palette, and a focus on content density.</p>
        </div>
      </div>
      <div class="ds-card">
        <span class="ds-swatch" style="background:#000000; border-color: rgba(255,255,255,0.3)"></span>
        <div class="ds-info">
          <h3>Base</h3>
          <p>Created by <strong>Uber</strong>. Base Web powers Uber's rider, driver, and Uber Eats platforms. A bold black-and-white system with generous radii, press-to-shrink interactions, and high contrast.</p>
        </div>
      </div>
      <div class="ds-card">
        <span class="ds-swatch" style="background:#18181B; border-color: rgba(255,255,255,0.3)"></span>
        <div class="ds-info">
          <h3>Default</h3>
          <p>Chassis UI's own <strong>neutral baseline</strong> theme. A clean, modern starting point with zinc tones, medium radii, and no strong brand identity — ideal for custom projects.</p>
        </div>
      </div>
    </div>
  </div>
</DocsLayout>

<script>
  import '@chassis-ui/core';
</script>

<style>
  .hero {
    max-width: 720px;
  }

  .tagline {
    font-size: var(--chassis-typography-font-size-lg, 1.25rem);
    color: var(--chassis-color-on-surface-variant, #49454f);
    margin-top: 1rem;
    line-height: 1.6;
  }

  .subtitle {
    margin-top: 0.75rem;
    color: var(--chassis-color-primary, #6200ee);
    font-weight: 500;
  }

  .demo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .demo-card {
    padding: 1.5rem;
    border: 1px solid var(--chassis-color-outline-variant, #cac4d0);
    border-radius: var(--chassis-shape-radius-lg, 16px);
    background: var(--chassis-color-surface, #fff);
  }

  .demo-card h3 {
    font-size: var(--chassis-typography-font-size-md, 1rem);
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .demo-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .feature {
    padding: 1.25rem;
  }

  .feature h3 {
    font-size: 1rem;
    margin-top: 0;
    margin-bottom: 0.5rem;
  }

  .feature p {
    font-size: 0.875rem;
    color: var(--chassis-color-on-surface-variant, #49454f);
  }

  .section-heading {
    margin-top: 3.5rem;
    margin-bottom: 0.5rem;
    font-size: var(--chassis-typography-font-size-xl, 1.25rem);
  }

  .section-intro {
    color: var(--chassis-color-on-surface-variant, #49454f);
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
  }

  .ds-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }

  .ds-card {
    display: flex;
    gap: 1rem;
    padding: 1.125rem;
    border: 1px solid var(--chassis-color-outline-variant, #cac4d0);
    border-radius: var(--chassis-shape-radius-md, 8px);
    background: var(--chassis-color-surface, #fff);
    transition: border-color 150ms ease;
  }

  .ds-card:hover {
    border-color: var(--chassis-color-outline, #79747e);
  }

  .ds-swatch {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 3px;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
  }

  .ds-info h3 {
    font-size: 0.9375rem;
    margin: 0 0 0.375rem 0;
  }

  .ds-info p {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--chassis-color-on-surface-variant, #49454f);
    margin: 0;
  }
</style>
