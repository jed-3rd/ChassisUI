---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
import CodeTabs from '../../components/CodeTabs.astro';
---

<DocsLayout title="Popover">
  <h1>Popover</h1>
  <p>A floating panel anchored to a trigger element. Supports click, hover, and manual triggers with automatic positioning and flip behavior.</p>

  <h2>Basic Usage</h2>
  <ComponentPreview title="Click trigger (default)">
    <chassis-popover>
      <button slot="trigger">Click me</button>
      <p>Popover content goes here.</p>
    </chassis-popover>
  </ComponentPreview>

  <CodeTabs
    webComponent={`<chassis-popover>
  <button slot="trigger">Click me</button>
  <p>Popover content goes here.</p>
</chassis-popover>`}
    react={`import { Popover } from '@chassisui/react';

<Popover>
  <button slot="trigger">Click me</button>
  <p>Popover content goes here.</p>
</Popover>`}
    angular={`import { PopoverComponent } from '@chassisui/angular';

@Component({
  imports: [PopoverComponent],
  template: \`
    <chassis-popover-wrapper>
      <button slot="trigger">Click me</button>
      <p>Popover content goes here.</p>
    </chassis-popover-wrapper>
  \`
})
export class MyComponent {}`}
    astro={`---
import Popover from '@chassisui/astro/Popover.astro';
---

<Popover>
  <button slot="trigger">Click me</button>
  <p>Popover content goes here.</p>
</Popover>`}
    svelte={`<script>
  import { Popover } from '@chassisui/svelte';
</script>

<Popover>
  <button slot="trigger">Click me</button>
  <p>Popover content goes here.</p>
</Popover>`}
  />

  <h2>Hover Trigger</h2>
  <ComponentPreview title="Opens on hover">
    <chassis-popover trigger="hover" placement="top">
      <button slot="trigger">Hover me</button>
      <p>This popover appears on hover.</p>
    </chassis-popover>
  </ComponentPreview>

  <h2>With Arrow</h2>
  <ComponentPreview title="Arrow pointing to trigger">
    <chassis-popover arrow>
      <button slot="trigger">With arrow</button>
      <p>Notice the arrow pointing to the trigger.</p>
    </chassis-popover>
  </ComponentPreview>

  <h2>Props</h2>
  <table class="props-table">
    <thead>
      <tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>trigger</code></td><td><code>'click' | 'hover' | 'manual'</code></td><td><code>'click'</code></td><td>How the popover is triggered</td></tr>
      <tr><td><code>placement</code></td><td><code>PopoverPlacement</code></td><td><code>'bottom'</code></td><td>Preferred placement relative to trigger</td></tr>
      <tr><td><code>offset</code></td><td><code>number</code></td><td><code>8</code></td><td>Distance from trigger in pixels</td></tr>
      <tr><td><code>arrow</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Show an arrow pointing to trigger</td></tr>
      <tr><td><code>open</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Whether the popover is visible</td></tr>
    </tbody>
  </table>

  <h2>Shadow Parts</h2>
  <table class="props-table">
    <thead>
      <tr><th>Part</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>content</code></td><td>The floating content panel</td></tr>
      <tr><td><code>arrow</code></td><td>The arrow element</td></tr>
    </tbody>
  </table>

  <h2>Events</h2>
  <table class="props-table">
    <thead>
      <tr><th>Event</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>chassis-open</code></td><td>Fired when the popover opens</td></tr>
      <tr><td><code>chassis-close</code></td><td>Fired when the popover closes</td></tr>
    </tbody>
  </table>

  <h2>Accessibility</h2>
  <ul>
    <li>Content panel uses <code>role="tooltip"</code></li>
    <li>Escape key closes the popover</li>
    <li>Click outside closes click-triggered popovers</li>
  </ul>
</DocsLayout>

<script>
  import '@chassisui/core/popover';
</script>

<style>
  .props-table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.875rem;
  }
  .props-table th,
  .props-table td {
    text-align: left;
    padding: 0.75rem;
    border-bottom: 1px solid var(--chassis-color-outline-variant, #cac4d0);
  }
  .props-table th {
    font-weight: 600;
    color: var(--chassis-color-on-surface-variant, #49454f);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
