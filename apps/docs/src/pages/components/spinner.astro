---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
import CodeTabs from '../../components/CodeTabs.astro';
---

<DocsLayout title="Spinner">
  <h1>Spinner</h1>
  <p>An animated loading indicator with configurable size.</p>

  <h2>Sizes</h2>
  <ComponentPreview title="Small / Medium / Large">
    <div style="display: flex; gap: 1.5rem; align-items: center;">
      <chassis-spinner size="sm"></chassis-spinner>
      <chassis-spinner size="md"></chassis-spinner>
      <chassis-spinner size="lg"></chassis-spinner>
    </div>
  </ComponentPreview>

  <CodeTabs
    webComponent={`<chassis-spinner></chassis-spinner>
<chassis-spinner size="sm"></chassis-spinner>
<chassis-spinner size="lg"></chassis-spinner>`}
    react={`import { Spinner } from '@chassis-ui/react';

<Spinner />
<Spinner size="sm" />
<Spinner size="lg" />`}
    angular={`import { SpinnerComponent } from '@chassis-ui/angular';

@Component({
  imports: [SpinnerComponent],
  template: \`
    <chassis-spinner-wrapper></chassis-spinner-wrapper>
  \`
})
export class MyComponent {}`}
    astro={`---
import Spinner from '@chassis-ui/astro/Spinner.astro';
---

<Spinner />
<Spinner size="lg" />`}
    svelte={`<script>
  import { Spinner } from '@chassis-ui/svelte';
</script>

<Spinner />
<Spinner size="lg" />`}
  />

  <h2>Props</h2>
  <table class="props-table">
    <thead>
      <tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>size</code></td><td><code>'sm' | 'md' | 'lg'</code></td><td><code>'md'</code></td><td>Spinner size (20/32/48px)</td></tr>
    </tbody>
  </table>

  <h2>Shadow Parts</h2>
  <table class="props-table">
    <thead>
      <tr><th>Part</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>base</code></td><td>The spinner container</td></tr>
      <tr><td><code>track</code></td><td>The background circle</td></tr>
      <tr><td><code>indicator</code></td><td>The animated arc</td></tr>
    </tbody>
  </table>

  <h2>Accessibility</h2>
  <ul>
    <li>Uses <code>role="progressbar"</code> for screen reader announcement</li>
    <li>Has <code>aria-label="Loading"</code> by default</li>
  </ul>
</DocsLayout>

<script>
  import '@chassis-ui/core/spinner';
</script>

<style>
  .props-table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.875rem;
  }
  .props-table th,
  .props-table td {
    text-align: left;
    padding: 0.75rem;
    border-bottom: 1px solid var(--chassis-color-outline-variant, #cac4d0);
  }
  .props-table th {
    font-weight: 600;
    color: var(--chassis-color-on-surface-variant, #49454f);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
