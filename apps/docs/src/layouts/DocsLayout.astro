---
import ThemeSwitcher from '@chassisui/astro/ThemeSwitcher.astro';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Chassis UI - Universal Design System Bridge' } = Astro.props;

const categories = [
  {
    title: 'Form',
    items: [
      { name: 'Button', href: '/components/button' },
      { name: 'Checkbox', href: '/components/checkbox' },
      { name: 'Date Picker', href: '/components/date-picker' },
      { name: 'Input', href: '/components/input' },
      { name: 'Radio', href: '/components/radio' },
      { name: 'Select', href: '/components/select' },
      { name: 'Slider', href: '/components/slider' },
      { name: 'Switch', href: '/components/switch' },
      { name: 'Textarea', href: '/components/textarea' },
      { name: 'Toggle Group', href: '/components/toggle-group' },
    ],
  },
  {
    title: 'Feedback',
    items: [
      { name: 'Alert', href: '/components/alert' },
      { name: 'Progress', href: '/components/progress' },
      { name: 'Skeleton', href: '/components/skeleton' },
      { name: 'Spinner', href: '/components/spinner' },
      { name: 'Toast', href: '/components/toast' },
    ],
  },
  {
    title: 'Navigation',
    items: [
      { name: 'Breadcrumb', href: '/components/breadcrumb' },
      { name: 'Link', href: '/components/link' },
      { name: 'Pagination', href: '/components/pagination' },
      { name: 'Tabs', href: '/components/tabs' },
    ],
  },
  {
    title: 'Layout',
    items: [
      { name: 'Accordion', href: '/components/accordion' },
      { name: 'Card', href: '/components/card' },
      { name: 'Divider', href: '/components/divider' },
      { name: 'Table', href: '/components/table' },
    ],
  },
  {
    title: 'Overlay',
    items: [
      { name: 'Dialog', href: '/components/dialog' },
      { name: 'Dropdown Menu', href: '/components/dropdown-menu' },
      { name: 'Modal', href: '/components/modal' },
      { name: 'Popover', href: '/components/popover' },
      { name: 'Tooltip', href: '/components/tooltip' },
    ],
  },
  {
    title: 'Data Display',
    items: [
      { name: 'Avatar', href: '/components/avatar' },
      { name: 'Badge', href: '/components/badge' },
      { name: 'Chip', href: '/components/chip' },
      { name: 'Icon', href: '/components/icon' },
    ],
  },
];
---

<!DOCTYPE html>
<html lang="en" data-theme="default" data-mode="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} | Chassis UI</title>
  <script is:inline>
    // Prevent flash: apply saved theme/mode before first paint
    (function() {
      var t = localStorage.getItem('chassis-theme');
      var m = localStorage.getItem('chassis-mode');
      if (!m) m = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      if (t) document.documentElement.setAttribute('data-theme', t);
      document.documentElement.setAttribute('data-mode', m);
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <div class="header-left">
      <a href="/" class="logo">
        <span class="logo-mark">⬡</span>
        <span class="logo-text">Chassis UI</span>
      </a>
      <nav class="header-nav">
        <a href="/getting-started/installation">Docs</a>
        <a href="/components/button">Components</a>
        <a href="/tokens">Tokens</a>
        <a href="/playground">Playground</a>
      </nav>
    </div>
    <div class="header-right">
      <ThemeSwitcher />
    </div>
  </header>

  <div class="site-layout">
    <aside class="sidebar">
      <nav>
        <div class="sidebar-section">
          <h3 class="sidebar-title">Getting Started</h3>
          <a class="sidebar-link" href="/getting-started/installation">Installation</a>
          <a class="sidebar-link" href="/getting-started/theming">Theming</a>
        </div>
        {categories.map(({ title, items }) => (
          <div class="sidebar-section">
            <h3 class="sidebar-title">{title}</h3>
            {items.map(({ name, href }) => (
              <a class="sidebar-link" href={href}>{name}</a>
            ))}
          </div>
        ))}
        <div class="sidebar-section">
          <h3 class="sidebar-title">Foundation</h3>
          <a class="sidebar-link" href="/tokens">Design Tokens</a>
        </div>
        <div class="sidebar-section">
          <h3 class="sidebar-title">Tools</h3>
          <a class="sidebar-link" href="/playground">Playground</a>
        </div>
      </nav>
    </aside>

    <main class="main-content">
      <slot />
    </main>
  </div>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid var(--chassis-color-outline-variant, #cac4d0);
    background: var(--chassis-color-surface, #fff);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--chassis-color-on-surface, #1c1b1f);
    font-weight: 700;
    font-size: 1.125rem;
  }

  .logo-mark {
    font-size: 1.5rem;
    color: var(--chassis-color-primary, #6200ee);
  }

  .header-nav {
    display: flex;
    gap: 1.5rem;
  }

  .header-nav a {
    color: var(--chassis-color-on-surface-variant, #49454f);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .header-nav a:hover {
    color: var(--chassis-color-on-surface, #1c1b1f);
    text-decoration: none;
  }

  .site-layout {
    display: flex;
    min-height: calc(100vh - 57px);
  }

  .sidebar {
    width: 240px;
    flex-shrink: 0;
    padding: 1.5rem 1rem;
    border-right: 1px solid var(--chassis-color-outline-variant, #cac4d0);
    background: var(--chassis-color-surface, #fff);
    overflow-y: auto;
    position: sticky;
    top: 57px;
    height: calc(100vh - 57px);
  }

  .sidebar-section {
    margin-bottom: 1.5rem;
  }

  .sidebar-title {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--chassis-color-on-surface-variant, #49454f);
    margin-bottom: 0.5rem;
  }

  .sidebar-link {
    display: block;
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
    color: var(--chassis-color-on-surface-variant, #49454f);
    text-decoration: none;
    border-radius: var(--chassis-shape-radius-sm, 4px);
    transition: all 100ms ease;
  }

  .sidebar-link:hover {
    color: var(--chassis-color-on-surface, #1c1b1f);
    background: var(--chassis-color-surface-variant, #e7e0ec);
    text-decoration: none;
  }

  .main-content {
    flex: 1;
    padding: 2rem 3rem;
    max-width: 960px;
  }

  @media (max-width: 768px) {
    .sidebar {
      display: none;
    }
    .main-content {
      padding: 1.5rem;
    }
    .header-nav {
      display: none;
    }
  }
</style>
