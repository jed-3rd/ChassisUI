---
export interface Props {
  href?: string;
  target?: string;
  variant?: 'default' | 'subtle';
  underline?: 'always' | 'hover' | 'none';
}

const { href = '', target = '', variant = 'default', underline = 'always' } = Astro.props;
---

<chassis-link href={href} target={target} variant={variant} underline={underline}>
  <slot />
</chassis-link>

<script>
  import '@chassisui/core/link';
</script>
