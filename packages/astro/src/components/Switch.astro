---
export interface Props {
  checked?: boolean;
  label?: string;
  disabled?: boolean;
  name?: string;
}

const { checked = false, label = '', disabled = false, name = '' } = Astro.props;
---

<chassis-switch checked={checked} label={label} disabled={disabled} name={name} />

<script>
  import '@chassis-ui/core/switch';
</script>
